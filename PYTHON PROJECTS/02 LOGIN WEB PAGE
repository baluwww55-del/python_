# login system using python :
# SIMPLE LOGIN WEBPAGE USING PYTHON :
username = input("Enter username: ")   # USERNAME AS A VARIBALE WHICH STORES THE DATE AND TIE INPUT FOR ENTERING THE  USERNAME : 
password = (input("Enter password: ") # here password is by string not an integer if integer we use as int . 

if username == "admin" and password == "1234":
    print("Access granted (Admin)")
elif username == "user" and password == "abcd":
    print("Access granted (User)")
elif username == "admin" or username == "user":
    print("Wrong password")
else:
    print("Access denied")

